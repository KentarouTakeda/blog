<!DOCTYPE html>
<html lang="<%- config.language %>">

<%- partial('_partial/head') %>

<body>
  <header class="navbar">
    <div class="navbar-container">
      <a href="<%- url_for() %>">
        <%= config.title %>
      </a>
      <button type="button" class="navbar-search" aria-label="検索">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
    </div>
  </header>
  <div class="search-panel" hidden>
    <div class="search-panel-inner">
      <input type="search" name="q" class="search-input" placeholder="記事を検索..." aria-label="記事を検索" autocomplete="off">
      <div class="search-empty" hidden>記事が見つかりませんでした</div>
      <div class="search-results"></div>
    </div>
  </div>
  <main>
    <%- body %>
  </main>
  <footer class="footer">
    <%= config.title %>
    Copyright &copy; <%= new Date().getFullYear() %> <%= config.author %>
  </footer>
</body>

</html>
